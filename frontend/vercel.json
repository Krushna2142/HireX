{
  "version": 2,
  "framework": "nextjs",

  "functions": {
    "app/api/**/route.ts": {
      "runtime": "nodejs18.x",
      "maxDuration": 60
    }
  },

  "regions": ["iad1"],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
