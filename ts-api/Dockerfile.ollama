FROM ollama/ollama:latest

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Copy entrypoint script
COPY ollama-entrypoint.sh /ollama-entrypoint.sh
RUN chmod +x /ollama-entrypoint.sh

EXPOSE 11434

HEALTHCHECK \
  --interval=30s \
  --timeout=15s \
  --start-period=120s \
  --retries=5 \
  CMD curl -f http://localhost:11434/api/tags || exit 1

# Override the base image entrypoint entirely
# The base image sets ENTRYPOINT ["ollama"] which intercepts CMD
# We bypass it completely with our own script
ENTRYPOINT []
CMD ["/bin/bash", "/ollama-entrypoint.sh"]
