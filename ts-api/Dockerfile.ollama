FROM ollama/ollama:latest

# Install curl for healthcheck
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Pre-pull model during build so container starts ready
# This avoids cold-start inference delays
RUN ollama serve & \
    sleep 10 && \
    ollama pull llama3.2:3b && \
    pkill ollama || true

EXPOSE 11434

HEALTHCHECK \
  --interval=30s \
  --timeout=15s \
  --start-period=120s \
  --retries=5 \
  CMD curl -f http://localhost:11434/api/tags || exit 1

CMD ["ollama", "serve"]